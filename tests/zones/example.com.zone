; ============================================================================
; Sample BIND zone file for example.com
;
; 動的な署名/別ツールでの生成が前提となるDNSSEC関連レコード
; (RRSIG, NSEC, NSEC3, NSEC3PARAM, ZONEMD) はコメントアウトしています。
; また、ゾーンファイルのデータとしてはそもそも存在し得ないメタレコード
; (TSIG, TKEY) や、レコードタイプではなくQTYPEであるANYについても
; コメントで理由を説明したうえで除外しています。
;
; ドラフト段階のRFCに基づくレコードタイプは含まれていません
; (列挙されたタイプはいずれも正式なRFCとして標準化済みです)。
; ============================================================================

$TTL 86400
$ORIGIN example.com.

; ----------------------------------------------------------------------------
; SOA / NS (ゾーンとして最低限必須)
; ----------------------------------------------------------------------------
@       IN SOA  ns1.example.com. hostmaster.example.com. (
                        2026071001 ; serial (YYYYMMDDnn)
                        3600       ; refresh (1 hour)
                        900        ; retry (15 minutes)
                        1209600    ; expire (2 weeks)
                        86400 )    ; minimum / negative cache TTL

        IN NS   ns1.example.com.
        IN NS   ns2.example.com.

; DNSKEY は dnssec-keygen が生成した鍵ファイルを $INCLUDE するのが定石
$INCLUDE example.com.dnskey

; 追加ホストレコードを別ファイルに分離して $INCLUDE する例
$INCLUDE example.com.hosts

; ----------------------------------------------------------------------------
; A / AAAA
; ----------------------------------------------------------------------------
ns1     IN A     192.0.2.1
ns2     IN A     192.0.2.2
ns1     IN AAAA  2001:db8::1
ns2     IN AAAA  2001:db8::2

www     IN A     192.0.2.10
www     IN AAAA  2001:db8::10

mail    IN A     192.0.2.20
mail2   IN A     192.0.2.21

*.wild  IN A     192.0.2.90

; ----------------------------------------------------------------------------
; CNAME / DNAME
; ----------------------------------------------------------------------------
ftp     IN CNAME www.example.com.
legacy  IN DNAME archive.example.com. ; legacy配下すべてをarchive配下へ委譲

; ----------------------------------------------------------------------------
; MX / TXT
; ----------------------------------------------------------------------------
@       IN MX 10 mail.example.com.
@       IN MX 20 mail2.example.com.

@       IN TXT "v=spf1 mx a:mail.example.com -all"

; SPF (RFC 4408) レコードタイプは RFC 7208 で Historic 化されており、
; 現在はTXTレコードでSPFを表現するのが標準です。参考として残しますが
@      IN SPF "v=spf1 mx a:mail.example.com -all"

; ----------------------------------------------------------------------------
; SRV / NAPTR / URI
; ----------------------------------------------------------------------------
_sip._tcp       IN SRV 10 60 5060 sipserver.example.com.
sipserver       IN A 192.0.2.30

_ldap._tcp      IN NAPTR 100 10 "S" "LDAP2+D2U" "" _ldap._tcp.example.com.

_https._tcp     IN URI 10 1 "https://www.example.com/"

; ----------------------------------------------------------------------------
; HTTPS / SVCB (RFC 9460)
; ----------------------------------------------------------------------------
@       IN HTTPS 1 . alpn=h2,h3
www     IN HTTPS 1 . alpn=h2

svc             IN A 192.0.2.40
_8443._tcp.svc  IN SVCB 1 svc.example.com. alpn=h2 port=8443

; ----------------------------------------------------------------------------
; TLSA (DANE)
; ----------------------------------------------------------------------------
_443._tcp.www   IN TLSA 3 1 1 (
    d2abde240d7cd3ee6b4b28c54df034b97983a1d16e8a410e4561cb106618e971 )

; ----------------------------------------------------------------------------
; SSHFP
; ----------------------------------------------------------------------------
ns1     IN SSHFP 1 1 a5e9e44c8142a57e4c70d04b2dbb652ef7cd3558
ns1     IN SSHFP 4 2 (
    513b28eb456f25db89fe68973f5946afba1499c07d011d5a3466bb33c76f8192 )

; ----------------------------------------------------------------------------
; CAA
; ----------------------------------------------------------------------------
@       IN CAA 0 issue "letsencrypt.org"
@       IN CAA 0 issuewild ";"
@       IN CAA 0 iodef "mailto:security@example.com"

; ----------------------------------------------------------------------------
; LOC
; ----------------------------------------------------------------------------
@       IN LOC 35 10 0.000 N 136 58 0.000 E 10.00m 100m 10m 10m

; ----------------------------------------------------------------------------
; HINFO / RP
; ----------------------------------------------------------------------------
ns1         IN HINFO "Generic-PC" "Linux"
@           IN RP hostmaster.example.com. admin-info.example.com.
admin-info  IN TXT "Contact the network operations team"

; ----------------------------------------------------------------------------
; AFSDB / HIP
; ----------------------------------------------------------------------------
@       IN AFSDB 1 afsdb.example.com.
afsdb   IN A 192.0.2.50

host-hip IN HIP ( 2 1B16A611E21577146EB10AC91B5EE027
    z+dS47XItL/GDrIZ736/ChYfkg3EvMkSaD2D0Rbot3lBwte5Ek2Rq3Q2Cxa3FEUU
    m8Cr6cDPCLrW49OEu6ObcQ== )

; ----------------------------------------------------------------------------
; DHCID
; ----------------------------------------------------------------------------
dhcphost IN DHCID ( M0LKbNXwrVdvwnLP+cLy5CAjRbsyRzwyr9DMcRBf54rnXWWJ )

; ----------------------------------------------------------------------------
; IPSECKEY
; ----------------------------------------------------------------------------
gw      IN IPSECKEY ( 10 1 2 192.0.2.60
    xXSx9Rxs5YKfvmrBRmae9qKRmUjoRW3d6QIt9rGU3a62fFz7D+nteciVRA77l9Cb
    /Lqwm8+Lt/n8xtDeSqwDBw== )

; ----------------------------------------------------------------------------
; CERT / SMIMEA / OPENPGPKEY
; ----------------------------------------------------------------------------
host-cert IN CERT PGP 0 0 (
    wLH49o6Tb9GlU9DIN4YcfFY+60kmG8DjaGPoNNopKhnA1Jx1dJgUqg== )

; 実運用ではオーナー名にローカルパートのSHA-256ハッシュを使いますが、
; ここでは分かりやすさのため簡略化した名前にしています。
smimea-example  IN SMIMEA 3 1 1 (
    9c95c410df69856955cc3e9c3574942985d0885c81740de118d0b4c901ac314e )

openpgp-example IN OPENPGPKEY (
    rDF/X4VG2slaNuarQ4drfCxQQHNYngYLFBR6FEHl3wDs9py6E1/aExsS5KXh5g== )

; ----------------------------------------------------------------------------
; APL
; ----------------------------------------------------------------------------
@       IN APL 1:192.0.2.0/24 !1:192.0.2.128/25 2:2001:db8::/32

; ----------------------------------------------------------------------------
; EUI48 / EUI64
; ----------------------------------------------------------------------------
printer1 IN EUI48 00-1A-2B-3C-4D-5E
sensor1  IN EUI64 00-1A-2B-3C-4D-5E-6F-70

; ----------------------------------------------------------------------------
; PTR
; PTRは通常 in-addr.arpa / ip6.arpa の逆引きゾーンで使用するため、
; example.com ゾーン内には本来書きません。参考として構文のみ記載します。
; ----------------------------------------------------------------------------
; 10.2.0.192.in-addr.arpa. IN PTR www.example.com.

; ----------------------------------------------------------------------------
; 委任先ゾーンの例(親ゾーン側に置くDSレコード)
; ※ named-checkzone は委任先のグルーレコードについて
;   "(out of zone) has no addresses records" という情報メッセージを
;   表示することがありますが、これは委任の仕組み上の正常な挙動であり
;   ロードエラーではありません。
; ----------------------------------------------------------------------------
secure          IN NS ns1.secure.example.com.
secure          IN NS ns2.secure.example.com.
ns1.secure      IN A 192.0.2.70
ns2.secure      IN A 192.0.2.71
secure          IN DS 12345 8 2 (
    E7B1692856465B7B66A9F25B54C3A9C84078C024F719F3FB370F8595B17DA08F )

; ----------------------------------------------------------------------------
; CSYNC
; (子ゾーン側から親ゾーンへNS/A/AAAA等の同期を促すためのレコード。
;  CSYNC自体は署名や実鍵との整合性検証を必要としないため静的に記載可能)
; ----------------------------------------------------------------------------
@       IN CSYNC 2026071001 3 A AAAA NS

; ----------------------------------------------------------------------------
; DNSSEC関連で「動的な署名」や「別ツールでの再生成」が前提となるため、
; 手書きでは意味を成さず本サンプルでは除去(コメントアウト)する
; レコード群
; ----------------------------------------------------------------------------

; RRSIG: 各RRsetに対する署名。dnssec-signzone によりゾーン署名の
;        過程で自動生成されるため、手書きすることはほぼない。
example.com. IN RRSIG A 8 2 86400 20260801000000 20260701000000 12345 example.com. (
    AbCdEf1234567890AbCdEf1234567890AbCdEf1234567890AbCdEf1234567890AA== )

; NSEC: 存在しないことの証明用レコード。ゾーン署名時に自動生成される。
www.example.com. IN NSEC mail.example.com. A AAAA RRSIG NSEC

; NSEC3 / NSEC3PARAM: NSECのハッシュ化版。こちらもゾーン署名時に
;        NSEC3PARAMで指定したパラメータに基づき自動生成される。
9D5RUJH8EGBAK2P0S9V03QAA9J8VQNQ6.example.com. IN NSEC3 1 0 10 AABBCCDD (
    9D6RUJH8EGBAK2P0S9V03QAA9J8VQNQ7 A AAAA RRSIG )
@ IN NSEC3PARAM 1 0 10 AABBCCDD

; ZONEMD: ゾーン全体の内容から計算するダイジェスト。ゾーンを変更する
;        たびに dnssec-signzone -j や zonemd ツール等で再計算が必要。
@       IN ZONEMD 2026071001 1 1 c68090d90a7aed716bc459f9340e3d7c1370d4d24b0c7...

; CDS / CDNSKEY: 子ゾーンが親ゾーンに「このDS/DNSKEYに同期してください」
;              と伝えるためのレコード。通常はレジストラへの自動登録用。
@       IN CDS     12345 8 2 6C0A40CD9755C3CBB40FAF136751933DBBE9D6C3D6A1817864AD3DF9A29262E4
@       IN CDNSKEY 257 3 13 (
    mdsswUyr3DPW132mOi8V9xESWE8jTo0dxCjjnopKl+GqJxpVXckHAeF+
    KkxLbxILfDLUT0rI5nJQ+EGsmNyPSw== )

; ----------------------------------------------------------------------------
; ゾーンファイルのデータとしてはそもそも存在し得ないため未記載のもの
; ----------------------------------------------------------------------------
; TSIG: RFC 8945のメタレコード。DNSメッセージのAdditionalセクションに
;       トランザクション認証のためだけに載るものであり、ゾーンファイル
;       には保存されない。
; TKEY: RFC 2930のメタレコード。共有鍵の帯域外合意/転送に使われる
;       一時的なものであり、こちらもゾーンファイルには保存されない。
; ANY : レコードタイプではなくQTYPE 255(「持っている全レコードをくれ」
;       という問い合わせ専用の値)であり、ゾーンデータとして書くことは
;       そもそもできない。

; ----------------------------------------------------------------------------
; $GENERATE の使用例
; ----------------------------------------------------------------------------

; host1.example.com. 〜 host50.example.com. を
; 192.0.2.101 〜 192.0.2.150 に一括で割り当てる例
$GENERATE 1-50 host$ IN A 192.0.2.${100}

; wifi-0.example.com. 〜 wifi-9.example.com. を
; 192.0.3.0 〜 192.0.3.9 に割り当てる例
$GENERATE 0-9 wifi-$ IN A 192.0.3.$

; 参考: 逆引きゾーン(2.0.192.in-addr.arpa.)で使う場合の典型例
; (このファイル=正引きゾーンには含めていません)
;$GENERATE 1-254 $ IN PTR host$.example.com.

; ----------------------------------------------------------------------------
; LOC / APL (Type 29, 42)
; ----------------------------------------------------------------------------
office  IN LOC  37 26 0.000 N 122 8 0.000 W 100.00m 1m 10000m 10m
hq      IN LOC  35 N 139 E 0m
network IN APL  1:192.168.0.0/24 !1:192.168.1.0/24 2:2001:db8::/32
; 経度(longitude), 緯度(latitude), 高度(altitude: メートル)
site.example.com.    3600  IN  GPOS  "-32.6866" "-70.1509" "12.0"
osi.example.com.     3600  IN  NSAP  0x47.0005.80.005a00.0000.0001.e133.ffffff000161.00
; サブアドレスなし
relay.example.com.   3600  IN  ISDN  "150862028003217"

; サブアドレス（004）あり
pbx.example.com.     3600  IN  ISDN  "150862028003217" "004"
route1.example.com.  3600  IN  X25   "311061700956"
